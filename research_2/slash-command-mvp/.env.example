# Copy this to .env and fill in your values
# DECISION: .env file for local development secrets.
# Production: K8s Secrets mounted as env vars, or Vault agent injector.

# Required: Anthropic API key for the LLM
LLM_API_KEY=your-anthropic-api-key-here

# Optional overrides (defaults shown)
REGISTRY_PORT=8001
MIDDLEWARE_PORT=8000
FRONTEND_PORT=3000
